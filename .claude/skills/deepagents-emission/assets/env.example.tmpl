# Copy this file to `.env` and fill in real values.
# `.env` is loaded by `langgraph dev` (see langgraph.json) and the bootstrap UI.
# Never commit `.env` — only `.env.example` belongs in version control.
#
# The generated app is provider-agnostic. Pick ONE of the provider blocks
# below by setting `DEEPAGENTS_MODEL` to the matching LangChain provider:model
# identifier, then fill in that provider's credentials.

# ----- DeepAgents core -----
DEEPAGENTS_MODEL={{MODEL_DEFAULT}}
DEEPAGENTS_APP_NAME={{APP_NAME_DEFAULT}}
DEEPAGENTS_ENABLE_MCP=false
DEEPAGENTS_DRY_RUN=false

# ----- Provider A: Anthropic (default) -----
# DEEPAGENTS_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ----- Provider B: OpenAI -----
# DEEPAGENTS_MODEL=openai:gpt-4o
# OPENAI_API_KEY=

# ----- Provider C: Azure OpenAI -----
# DEEPAGENTS_MODEL=azure_openai:<your-deployment-name>
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>

# ----- Provider D: AWS Bedrock (uncomment + pip install langchain-aws) -----
# DEEPAGENTS_MODEL=bedrock_converse:anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ----- LangSmith tracing (optional) -----
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT={{APP_NAME_DEFAULT}}

{{MCP_ENV_VARS_BLOCK}}
