#!/usr/bin/env bash
# bootstrap_ui.sh — Clone (or update) langchain-ai/deep-agents-ui into ./ui/
# and wire it to this DeepAgents app's langgraph dev server.
#
# Generated by harness2deepagents. The UI is the default frontend for the
# converted DeepAgents app. Re-running this script is idempotent.

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
UI_DIR="$HERE/ui"
UI_REPO="https://github.com/langchain-ai/deep-agents-ui.git"
UI_REF="${DEEP_AGENTS_UI_REF:-main}"

# LangGraph dev defaults — must match langgraph.json graph id and `langgraph dev` port.
LANGGRAPH_URL="${LANGGRAPH_URL:-http://127.0.0.1:2024}"
AGENT_ID="${AGENT_ID:-deepagent}"

echo "[bootstrap_ui] target: $UI_DIR"
echo "[bootstrap_ui] repo:   $UI_REPO@$UI_REF"

if [ -d "$UI_DIR/.git" ]; then
  echo "[bootstrap_ui] updating existing UI checkout"
  git -C "$UI_DIR" fetch --depth 1 origin "$UI_REF"
  git -C "$UI_DIR" checkout -q "$UI_REF"
  git -C "$UI_DIR" reset --hard "origin/$UI_REF"
else
  echo "[bootstrap_ui] cloning $UI_REPO into $UI_DIR"
  git clone --depth 1 --branch "$UI_REF" "$UI_REPO" "$UI_DIR"
fi

ENV_LOCAL="$UI_DIR/.env.local"
if [ ! -f "$ENV_LOCAL" ]; then
  cat > "$ENV_LOCAL" <<EOF
# Auto-generated by bootstrap_ui.sh — points the UI at this app's langgraph dev server.
NEXT_PUBLIC_DEPLOYMENT_URL=$LANGGRAPH_URL
NEXT_PUBLIC_AGENT_ID=$AGENT_ID
EOF
  echo "[bootstrap_ui] wrote $ENV_LOCAL"
else
  echo "[bootstrap_ui] keeping existing $ENV_LOCAL (delete it to regenerate)"
fi

cat <<'EOF'

[bootstrap_ui] done.

Next steps:
  1. Start the agent backend (this directory):
       langgraph dev
     This serves the graph defined in langgraph.json at http://127.0.0.1:2024.

  2. In another terminal, start the UI:
       cd ui
       pnpm install      # or: npm install / yarn install
       pnpm dev          # serves the UI at http://localhost:3000

  3. Open http://localhost:3000 in a browser.

The UI talks to the backend via langgraph SDK using the URL and agent ID in
ui/.env.local. Override DEEP_AGENTS_UI_REF / LANGGRAPH_URL / AGENT_ID when
re-running this script if your setup differs.
EOF
